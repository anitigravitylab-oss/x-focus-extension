{
  "manifest_version": 3,
  "name": "Xフォーカスフィルター",
  "version": "0.1.0",
  "description": "x.comのタイムラインから、キーワード条件に合わない投稿を非表示にします。",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "action": {
    "default_title": "Xフォーカスフィルター",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
