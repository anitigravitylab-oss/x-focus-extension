{
  "manifest_version": 3,
  "name": "X Focus Filter",
  "version": "0.1.0",
  "description": "Hide low-signal posts on x.com using keyword-based focus filters.",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "action": {
    "default_title": "X Focus Filter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
